---
import HeaderLink from "./HeaderLink.astro";
import CardWrapper from "./CardWrapper.astro";
import ThemeToggle from "./ThemeToggle.astro";

const otrLink = "/otr/";

const links = [
  {
    name: "Home",
    location: "/",
  },
  {
    name: "About",
    location: "/about",
  },
  {
    name: "Blog",
    location: "/blog",
  },
  {
    name: "Photography",
    location: "/photography",
  },
  {
    name: "Projects",
    location: "/projects",
  },
  {
    name: "Partner",
    location: "/partner",
  },
  {
    name: "OTR",
    location: otrLink,
  },
];
---

<header class="my-4 w-full">
  <CardWrapper class="w-full">
    <nav class="flex flex-col items-center lg:flex-row lg:justify-between">
      <h2>
        <a href="/">
          <img
            src="/branding/herrerake-logo-oleo-script-swash-caps-black.png"
            loading="lazy"
            width="156"
            alt="Herrerake Logo"
            class="h-6 w-auto dark:invert dark:brightness-200"
          /></a
        >
      </h2>
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mt-4 lg:mt-0">
        {
          links.map((link) => (
            <HeaderLink href={link.location}>
              {link.name}
            </HeaderLink>
          ))
        }
        <ThemeToggle />
      </div>
    </nav>
  </CardWrapper>
</header>

<style>
  h2 {
    margin: 0;
    font-size: 1em;
  }
  h2 a,
  h2 a.active {
    text-decoration: none;
  }
  nav a {
    color: var(--black);
    border-bottom: 4px solid transparent;
    text-decoration: none;
  }
  nav a.active {
    text-decoration: none;
  }
</style>
